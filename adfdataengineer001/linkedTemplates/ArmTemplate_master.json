{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfdataengineer001"
		},
		"ServiceNow1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ServiceNow1'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdataengineer0411.dfs.core.windows.net"
		},
		"AzureDataLakeStorage2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdataengineer0411.dfs.core.windows.net"
		},
		"AzureDataLakeStorage3_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdataengineer0411.dfs.core.windows.net"
		},
		"AzureDataLakeStorage4_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdataengineer0411.dfs.core.windows.net"
		},
		"AzureDataLakeStorage5_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdataengineer0411.dfs.core.windows.net"
		},
		"AzureKeyVault1_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://dataengkeyvault0411.vault.azure.net/"
		},
		"File_moment_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://dataengkeyvault0411.vault.azure.net/"
		},
		"ServiceNow1_properties_typeProperties_endpoint": {
			"type": "string",
			"defaultValue": "https://cbre.service-now.com"
		},
		"ServiceNow1_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "Vattikota.Vishwaksena@cbre.com"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfdataengineer001_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ServiceNow1_password": {
						"value": "[parameters('ServiceNow1_password')]"
					},
					"AzureKeyVault1_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault1_properties_typeProperties_baseUrl')]"
					},
					"File_moment_properties_typeProperties_baseUrl": {
						"value": "[parameters('File_moment_properties_typeProperties_baseUrl')]"
					},
					"ServiceNow1_properties_typeProperties_endpoint": {
						"value": "[parameters('ServiceNow1_properties_typeProperties_endpoint')]"
					},
					"ServiceNow1_properties_typeProperties_username": {
						"value": "[parameters('ServiceNow1_properties_typeProperties_username')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"AzureDataLakeStorage2_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage2_properties_typeProperties_url')]"
					},
					"AzureDataLakeStorage3_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage3_properties_typeProperties_url')]"
					},
					"AzureDataLakeStorage4_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage4_properties_typeProperties_url')]"
					},
					"AzureDataLakeStorage5_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage5_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}